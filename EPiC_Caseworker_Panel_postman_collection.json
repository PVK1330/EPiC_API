      "name": "Auth",
      "item": [
        {
          "name": "Login (Caseworker)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"caseworker@epic.com\",\n  \"password\": \"cwpass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
