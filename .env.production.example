# Production — API host: server.elitepic.co.uk
# Frontend (browser): cms.elitepic.co.uk

NODE_ENV=production
PORT=5000

PLATFORM_DOMAIN=elitepic.co.uk
FRONTEND_URL=https://cms.elitepic.co.uk
CORS_ORIGINS=

API_URL=https://server.elitepic.co.uk/api
BASE_URL=https://server.elitepic.co.uk

REDIRECT_URI=https://server.elitepic.co.uk
MICROSOFT_REDIRECT_URI=https://cms.elitepic.co.uk/auth/microsoft/callback

# ── Security ──────────────────────────────────────────────────────────────
# Trust proxy when behind nginx/Cloudflare (required for rate-limiters & IP)
TRUST_PROXY=true

# Helmet CSP report-only mode (set to "true" for gradual rollout,
# "false" for full enforcement once no CSP violations are reported)
CSP_REPORT_ONLY=false

# REQUIRED secrets — generate UNIQUE values per environment, never reuse one for both.
#   JWT_SECRET             : signs JWTs           — node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   SETTINGS_ENCRYPTION_KEY: AES-256 secrets-at-rest (64 hex chars / 32 bytes), MUST differ from JWT_SECRET
#                            node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The server aborts startup if SETTINGS_ENCRYPTION_KEY is missing, malformed, or equal to JWT_SECRET.
JWT_SECRET=
SETTINGS_ENCRYPTION_KEY=

# Database, Stripe, email — set on VPS (copy from your live .env)
