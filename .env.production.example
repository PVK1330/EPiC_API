# Production — API host: server.elitepic.co.uk
# Frontend (browser): cms.elitepic.co.uk

NODE_ENV=production
PORT=5000

PLATFORM_DOMAIN=elitepic.co.uk
FRONTEND_URL=https://cms.elitepic.co.uk
CORS_ORIGINS=

API_URL=https://server.elitepic.co.uk/api
BASE_URL=https://server.elitepic.co.uk

REDIRECT_URI=https://server.elitepic.co.uk
MICROSOFT_REDIRECT_URI=https://cms.elitepic.co.uk/auth/microsoft/callback

# ── Security ──────────────────────────────────────────────────────────────
# Trust proxy when behind nginx/Cloudflare (required for rate-limiters & IP)
TRUST_PROXY=true

# Helmet CSP report-only mode (set to "true" for gradual rollout,
# "false" for full enforcement once no CSP violations are reported)
CSP_REPORT_ONLY=false

# Database, Stripe, JWT, email — set on VPS (copy from your live .env)
