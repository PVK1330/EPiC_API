NODE_ENV=development
PORT=5000

# Platform registry database (organisations + users for login)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=epic
DB_USER=epic
DB_PASSWORD=epic123
# Legacy alias (optional)
DB_PASS=epic123

# false = local Docker / Hostinger VPS Postgres; true = Render and similar
DB_SSL=false

# Tenant database provisioning (requires CREATEDB or superuser)
TENANT_DB_CREATOR_USER=postgres
TENANT_DB_CREATOR_PASSWORD=your-postgres-admin-password
DB_MAINTENANCE_DATABASE=postgres
TENANT_DB_PREFIX=epic_
TENANT_PHYSICAL_DATABASES=true

# Multi-tenant host (subdomains: http://{slug}.localhost:5173)
PLATFORM_DOMAIN=localhost
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:5000/api
BASE_URL=http://localhost:5000

# Optional: default org for open registration on main domain only
DEFAULT_ORGANISATION_ID=

JWT_SECRET=change-me-in-production
EMAIL_USER=
EMAIL_PASS=

# Seeded superadmin only (organisations via API, not seeder)
ADMIN_DEFAULT_PASSWORD=Admin@123

# SQL migrations: npm run migrate | migrate:platform | migrate:tenants
