NODE_ENV=development
PORT=5000

# Server timezone (defaults to Asia/Kolkata if not set)
# TZ=Asia/Kolkata

# Database (adjust per environment)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=epic_central
DB_USER=postgres
DB_PASSWORD=
DB_PASS=
DB_SSL=false

TENANT_DB_CREATOR_USER=
TENANT_DB_CREATOR_PASSWORD=
DB_MAINTENANCE_DATABASE=postgres
TENANT_DB_PREFIX=epic_
TENANT_PHYSICAL_DATABASES=true

# Local URLs (no trailing slash on BASE_URL)
PLATFORM_DOMAIN=localhost
FRONTEND_URL=http://localhost:5173
# Optional extra browser origins (comma-separated), merged with FRONTEND_URL
CORS_ORIGINS=
API_URL=http://localhost:5000/api
BASE_URL=http://localhost:5000

# OAuth redirects — must match provider console entries
REDIRECT_URI=http://localhost:5000
MICROSOFT_REDIRECT_URI=http://localhost:5173/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/common

CLIENT_ID=
CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

SETTINGS_ENCRYPTION_KEY=
JWT_SECRET=

EMAIL_USER=
EMAIL_PASS=

# Live (see .env.production.example):
#   Frontend  → cms.elitepic.co.uk
#   Backend   → server.elitepic.co.uk
# PLATFORM_DOMAIN=elitepic.co.uk
# FRONTEND_URL=https://cms.elitepic.co.uk
# API_URL=https://server.elitepic.co.uk/api
# BASE_URL=https://server.elitepic.co.uk
# Tenant org subdomains (*.elitepic.co.uk) are also allowed when PLATFORM_DOMAIN is set.
