{
  "info": {
    "_postman_id": "a1b2c3d4-settings-api-elitepic",
    "name": "ElitePic — Admin Settings API",
    "description": "Settings routes mounted at `/api/settings`. Requires `verifyToken` + ADMIN role.\n\n**Environment:** set `baseUrl` (e.g. `http://72.61.188.186:5001`) and `token` (JWT). Authorization header: `Bearer {{token}}`.\n\n**Email template keys:** `payment`, `doc`, `opened`, `expiry`, `welcome`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://72.61.188.186:5001"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "visaTypeId",
      "value": "1"
    },
    {
      "key": "petitionTypeId",
      "value": "1"
    },
    {
      "key": "caseCategoryId",
      "value": "1"
    },
    {
      "key": "emailTemplateKey",
      "value": "payment"
    }
  ],
  "item": [
    {
      "name": "Profile & preferences",
      "item": [
        {
          "name": "GET /me — current admin profile & preferences",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/settings/me"
          }
        },
        {
          "name": "PATCH /me — preferences only (no profile fields)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"avatar_url\": \"https://example.com/avatars/admin.png\",\n  \"two_factor_enabled\": false,\n  \"email_notifications\": true,\n  \"case_updates\": true,\n  \"payment_alerts\": false,\n  \"timezone\": \"UTC-05:00 Eastern Time\",\n  \"language\": \"English\",\n  \"date_format\": \"MM/DD/YYYY\",\n  \"data_collection\": false\n}"
            },
            "url": "{{baseUrl}}/api/settings/me"
          }
        },
        {
          "name": "PATCH /me — profile + preferences (all fields)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Admin\",\n  \"last_name\": \"User\",\n  \"email\": \"admin@example.com\",\n  \"country_code\": \"+1\",\n  \"mobile\": \"5551234567\",\n  \"avatar_url\": null,\n  \"two_factor_enabled\": false,\n  \"email_notifications\": true,\n  \"case_updates\": true,\n  \"payment_alerts\": false,\n  \"timezone\": \"UTC-05:00 Eastern Time\",\n  \"language\": \"English\",\n  \"date_format\": \"MM/DD/YYYY\",\n  \"data_collection\": false\n}"
            },
            "url": "{{baseUrl}}/api/settings/me"
          }
        },
        {
          "name": "POST /change-password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"YourCurrentPassword123\",\n  \"new_password\": \"YourNewPassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/settings/change-password"
          }
        }
      ]
